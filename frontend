import 'package:flutter/material.dart';

void main() {
  runApp(SafeTravelApp());
}

class SafeTravelApp extends StatelessWidget {
  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      title: 'SafeTravel AI',
      theme: ThemeData.dark(),
      home: HomeScreen(),
    );
  }
}

class HomeScreen extends StatelessWidget {
  int getSafetyScore() {
    int score = 50;

    // simple logic
    DateTime now = DateTime.now();
    if (now.hour > 20) {
      score += 20; // night risk
    }

    return score;
  }

  @override
  Widget build(BuildContext context) {
    int safetyScore = getSafetyScore();

    return Scaffold(
      appBar: AppBar(title: Text("SafeTravel AI")),
      body: Column(
        mainAxisAlignment: MainAxisAlignment.center,
        children: [
          Text("Safety Score: $safetyScore",
              style: TextStyle(fontSize: 24)),
          
          SizedBox(height: 20),

          ElevatedButton(
            onPressed: () {
              print("SOS Triggered!");
            },
            child: Text("🚨 SOS"),
          ),
        ],
      ),
    );
  }
}
